{
  "name": "@agentic-workflow-kit/repo-template",
  "version": "0.0.0",
  "description": "Describe this repo. (Rename to @agentic-workflow-kit/<repo> after generating.)",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev:setup": "bash scripts/dev-setup.sh",
    "worktree:new": "bash scripts/worktree-new.sh",
    "format": "prettier --write \"**/*.{md,yml,yaml,json}\"",
    "format:check": "prettier --check \"**/*.{md,yml,yaml,json}\"",
    "lint": "pnpm format:check",
    "check": "pnpm lint"
  },
  "devDependencies": {
    "prettier": "^3.6.2"
  }
}
